<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="dev.emoforge.post.mapper.SearchMapper">

    <!-- ========================================================
         공용 게시글 검색 (통합검색 + 필터 구조)
         ======================================================== -->

    <!-- ========================================================
         검색 결과 매핑
         ======================================================== -->
    <resultMap id="PostSearchResultMap" type="dev.emoforge.post.dto.query.PostSearchResultDTO">
        <id column="id"              property="id"/>
        <result   column="title"           property="title"/>
        <result   column="content"         property="content"/>
        <result   column="created_at"      property="createdAt"/>
        <result   column="member_uuid"     property="memberUuid"/>
        <result   column="category_id"     property="categoryId"/>
        <result   column="category_name"   property="categoryName"/>
        <result   column="comment_count"   property="commentCount"/>
        <result   column="author_nickname"   property="authorNickname"/>
        <result   column="commentCount"   property="commentCount"/>
    </resultMap>


    <!-- ========================================================
         공용 WHERE 조건 (목록/카운트 공통 사용)
         ======================================================== -->
    <sql id="searchWhereConditions">

        <!-- 카테고리 ID 필터 -->
        <if test="filter.categoryId != null and filter.categoryId > 0">
            AND p.category_id = #{filter.categoryId}
        </if>

        <!-- 기간 필터 -->
        <if test="filter.startDate != null and filter.endDate != null">
            AND p.created_at BETWEEN #{filter.startDate} AND #{filter.endDate}
        </if>

        <!-- 통합 키워드 검색 -->
        <if test="filter.keyword != null and filter.keyword != ''">

            AND (
            <trim prefixOverrides="OR">

                <!-- 제목 -->
                <if test="filter.titleChecked">
                    OR p.title LIKE CONCAT('%', #{filter.keyword}, '%')
                </if>

                <!-- 내용 -->
                <if test="filter.contentChecked">
                    OR p.content LIKE CONCAT('%', #{filter.keyword}, '%')
                </if>

                <!-- 댓글 -->
                <if test="filter.commentChecked">
                    OR EXISTS (
                    SELECT 1
                    FROM comment cm
                    WHERE cm.post_id = p.id
                    AND cm.content LIKE CONCAT('%', #{filter.keyword}, '%')
                    )
                </if>

                <!-- 카테고리명 -->
                <if test="filter.categoryChecked">
                    OR c.name LIKE CONCAT('%', #{filter.keyword}, '%')
                </if>

                <!-- 작성자 -->
                <if test="filter.authorChecked">
                    OR m.username LIKE CONCAT('%', #{filter.keyword}, '%')
                </if>

            </trim>
            )

        </if>

    </sql>


    <!-- ========================================================
         조건 기반 게시글 목록 검색 (페이징 포함)
         ======================================================== -->
    <select id="searchPostsByFilter" resultMap="PostSearchResultMap">

        SELECT
        p.id,
        p.title,
        p.content,
        p.created_at,
        p.member_uuid,
        p.category_id,
        m.nickname AS author_nickname,
        c.name AS category_name,
        (
        SELECT COUNT(*)
        FROM comment cm
        WHERE cm.post_id = p.id
        ) AS comment_count

        FROM post p
        LEFT JOIN category c ON p.category_id = c.id
        LEFT JOIN member m ON p.member_uuid = m.uuid

        WHERE 1 = 1
        <include refid="searchWhereConditions"/>

        <!-- 정렬 -->
        ORDER BY
        <choose>
            <when test="page.sort == 'title'">p.title</when>
            <when test="page.sort == 'viewCount'">p.view_count</when>
            <when test="page.sort == 'id'">p.id</when>
            <otherwise>p.created_at</otherwise>
        </choose>
        <choose>
            <when test="page.direction.name() == 'ASC'">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>

        LIMIT #{page.size} OFFSET #{page.offset}

    </select>


    <!-- ========================================================
         조건 기반 게시글 검색 개수
         ======================================================== -->
    <select id="countPostsByFilter" resultType="int">

        SELECT COUNT(DISTINCT p.id)

        FROM post p
        LEFT JOIN category c ON p.category_id = c.id
        LEFT JOIN member m ON p.member_uuid = m.uuid

        WHERE 1 = 1
        <include refid="searchWhereConditions"/>

    </select>

</mapper>